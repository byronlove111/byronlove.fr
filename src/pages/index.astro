		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<title>byronlove</title>
		<meta name="description" content="Cursor ambassador and engineer based in Paris, building full-stack products and AI-native infrastructure from 0 → 1." />
		<meta name="keywords" content="Byron Love, Software Engineer, Paris, JavaScript, TypeScript, AI, OpenSource Together, Cursor, Châtaigne" />
		<meta name="author" content="Byron Love" />
		<meta property="og:title" content="byronlove" />
		<meta property="og:description" content="Cursor ambassador and engineer based in Paris, building full-stack products and AI-native infrastructure from 0 → 1." />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content="byronlove" />
		<meta name="twitter:description" content="Cursor ambassador and engineer based in Paris, building full-stack products and AI-native infrastructure from 0 → 1." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
