---
import '../styles/global.css';
import BottomFade from '../components/BottomFade.astro';
import SmoothScroll from '../components/SmoothScroll.astro';

const items = [
  { label: "Moog Subsequent 37", href: "https://www.moogmusic.com/synthesizers/subsequent-37/" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>byronlove</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div style="max-width: 680px; margin: 0 auto; padding: 4rem 1.5rem 6rem;">
      <nav style="margin-bottom: 3rem;">
        <a href="/" style="font-family: 'Lora', Georgia, serif; font-size: 0.9375rem; color: #888; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='#1a1a1a'" onmouseout="this.style.color='#888'"><svg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='1.5' stroke='currentColor' style='width:1em;height:1em;vertical-align:middle;display:inline-block;'><path stroke-linecap='round' stroke-linejoin='round' d='M15.75 19.5 8.25 12l7.5-7.5' /></svg> byron love</a>
      </nav>

      <h1 style="font-family: 'Lora', Georgia, serif; font-size: 1.875rem; font-weight: 400; color: #1a1a1a; margin: 0 0 0.5rem; letter-spacing: -0.01em;">
        Synthesizers
      </h1>
      <p style="font-family: 'Lora', Georgia, serif; font-size: 0.9375rem; color: #888; font-style: italic; margin: 0 0 2.5rem;">
        Gear I own
      </p>

      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column;">
        {items.map(item => (
          <li style="border-top: 1px solid #E8E7E2;">
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              style="display: block; padding: 0.75rem 0; font-family: 'Lora', Georgia, serif; font-size: 1rem; color: #1a1a1a; line-height: 1.5; text-decoration: none; transition: opacity 0.15s;"
              onmouseover="this.style.opacity='0.5'"
              onmouseout="this.style.opacity='1'"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <BottomFade />
		<SmoothScroll />
  </body>
</html>
