---
import '../styles/global.css';
import BottomFade from '../components/BottomFade.astro';

const items = [
  { label: "Moog Subsequent 37", href: "https://www.moogmusic.com/synthesizers/subsequent-37/" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>Synthesizers — Byron Love</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div style="max-width: 680px; margin: 0 auto; padding: 4rem 1.5rem 6rem;">
      <nav style="margin-bottom: 3rem;">
        <a href="/" style="font-family: ui-monospace, 'SF Mono', monospace; font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase; color: #888; text-decoration: none;">
          ← Byron Love
        </a>
      </nav>

      <h1 style="font-family: 'Lora', Georgia, serif; font-size: 1.875rem; font-weight: 400; color: #1a1a1a; margin: 0 0 0.5rem; letter-spacing: -0.01em;">
        Synthesizers
      </h1>
      <p style="font-family: 'Lora', Georgia, serif; font-size: 0.9375rem; color: #888; font-style: italic; margin: 0 0 2.5rem;">
        Gear I own
      </p>

      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
        {items.map(item => (
          <li style="border-top: 1px solid #E8E7E2; padding-top: 0.75rem;">
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              style="font-family: 'Lora', Georgia, serif; font-size: 1rem; color: #1a1a1a; text-decoration: underline; text-underline-offset: 2px;"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <BottomFade />
  </body>
</html>
