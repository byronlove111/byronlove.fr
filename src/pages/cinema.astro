---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Cinema - Byron Love</title>
	</head>
	<body>
		<div class="min-h-screen bg-white">
			<div class="container max-w-2xl mx-auto px-4 py-16">
				<div class="space-y-6">
					<div class="space-y-2">
						<h1 class="text-2xl font-normal text-black">Cinema</h1>
						<p class="text-sm text-black">
							<a href="/" class="underline hover:no-underline transition-all">
								← back
							</a>
						</p>
					</div>

					<div class="pt-4">
						<p class="text-sm text-black leading-relaxed mb-4">
							Movies that made me fall in love with cinema
						</p>
						<ul class="space-y-2 list-disc list-inside">
							<li class="text-sm text-black leading-relaxed">
								Phantom of the Paradise (Brian De Palma)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Seven (David Fincher)
							</li>
							<li class="text-sm text-black leading-relaxed">
								The Silence of the Lambs (Jonathan Demme)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Bohemian Rhapsody (Bryan Singer)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Catch Me If You Can (Steven Spielberg)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Get Out (Jordan Peele)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Parasite (Bong Joon-ho)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Drive (Nicolas Winding Refn)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Home Alone (Chris Columbus)
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
