---
import { getCollection } from "astro:content";
import CodeBlock from "../../components/blog/CodeBlock";
import Screenshot from "../../components/blog/Screenshot";
import Callout from "../../components/blog/Callout";
import AnimatedSection from "../../components/blog/AnimatedSection";
import Demo from "../../components/blog/Demo";
import Video from "../../components/blog/Video";
import "../../styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: `${post.data.slug_base}-${post.data.lang}` },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const { title, date, description, lang, slug_base } = post.data;

const otherLang = lang === "en" ? "fr" : "en";
const allPosts = await getCollection("blog");
const otherPost = allPosts.find(
  (p) => p.data.slug_base === slug_base && p.data.lang === otherLang
);

function formatDate(date: Date) {
  return date.toLocaleDateString(lang === "fr" ? "fr-FR" : "en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const blogComponents = { CodeBlock, Screenshot, Callout, AnimatedSection, Demo, Video };
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Byron Love</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
  </head>
  <body>
    <div class="min-h-screen bg-white">
      <div class="container max-w-2xl mx-auto px-4 py-16">
        <div class="space-y-6">
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <a href="/blog" class="text-sm text-black underline hover:no-underline transition-all">
                ← blog
              </a>
              {otherPost && (
                <a
                  href={`/blog/${slug_base}-${otherLang}`}
                  class="text-xs text-gray-400 hover:text-black transition-colors underline hover:no-underline"
                >
                  {otherLang === "fr" ? "Lire en français" : "Read in english"}
                </a>
              )}
            </div>
            <h1 class="text-2xl font-normal text-black pt-4">{title}</h1>
            <p class="text-xs text-gray-400">{formatDate(date)}</p>
          </div>

          <article class="prose-blog pt-2">
            <Content components={blogComponents} />
          </article>
        </div>
      </div>
    </div>
  </body>
</html>

<style is:global>
  .prose-blog {
    color: #000;
    font-size: 0.875rem;
    line-height: 1.75;
  }

  .prose-blog p {
    margin-bottom: 1.25rem;
  }

  .prose-blog h2 {
    font-size: 1rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #000;
  }

  .prose-blog h3 {
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #000;
  }

  .prose-blog a {
    text-decoration: underline;
    color: #000;
    transition: text-decoration 0.15s;
  }

  .prose-blog a:hover {
    text-decoration: none;
  }

  .prose-blog ul {
    list-style-type: disc;
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .prose-blog ol {
    list-style-type: decimal;
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .prose-blog li {
    margin-bottom: 0.25rem;
  }

  .prose-blog code {
    font-family: ui-monospace, monospace;
    font-size: 0.8125rem;
    background: #f5f5f5;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    color: #000;
  }

  .prose-blog pre {
    background: #f5f5f5;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .prose-blog pre code {
    background: transparent;
    padding: 0;
  }

  .prose-blog blockquote {
    border-left: 2px solid #e5e5e5;
    padding-left: 1rem;
    color: #666;
    margin-bottom: 1.25rem;
  }

  .prose-blog hr {
    border: none;
    border-top: 1px solid #f0f0f0;
    margin: 2rem 0;
  }

  .prose-blog strong {
    font-weight: 500;
  }
</style>
