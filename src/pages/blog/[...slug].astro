---
import { getCollection } from "astro:content";
import ScreenshotIsland from "../../components/blog/ScreenshotIsland.astro";
import VideoIsland from "../../components/blog/VideoIsland.astro";
import AnimatedSection from "../../components/blog/AnimatedSection";
import Demo from "../../components/blog/Demo";
import "../../styles/global.css";
import BottomFade from "../../components/BottomFade.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: `${post.data.slug_base}-${post.data.lang}` },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const { title, date, description, lang, slug_base } = post.data;

const otherLang = lang === "en" ? "fr" : "en";
const allPosts = await getCollection("blog");
const otherPost = allPosts.find(
  (p) => p.data.slug_base === slug_base && p.data.lang === otherLang
);

function formatDate(date: Date) {
  return date.toLocaleDateString(lang === "fr" ? "fr-FR" : "en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const blogComponents = { Screenshot: ScreenshotIsland, Video: VideoIsland, AnimatedSection, Demo };
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — Byron Love</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="article-body">
    <nav class="article-nav-static" aria-label={lang === "fr" ? "Navigation article" : "Article navigation"}>
      <div class="article-nav-inner">
        <a href="/" class="nav-back"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 1em; height: 1em; vertical-align: middle; display: inline-block;">
  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
</svg> byron love</a>
        {otherPost && (
          <a href={`/blog/${slug_base}-${otherLang}`} class="nav-lang">
            {otherLang === "fr" ? "Lire en français" : "Read in english"}
          </a>
        )}
      </div>
    </nav>

    <main class="article-main">
      <header class="article-header">
        <div class="article-meta">
          <span>{formatDate(date)}</span>
        </div>
        <h1 class="article-title">{title}</h1>
        {description && <p class="article-description">{description}</p>}
      </header>

      <article class="prose-blog">
        <Content components={blogComponents} />
      </article>
    </main>
    <BottomFade />
    <script>
      import { playSound } from "../../lib/ui-sounds";
      document.querySelectorAll(".nav-back, .nav-lang").forEach((el) => {
        el.addEventListener("click", () => { playSound("key-press"); });
      });
    </script>
  </body>
</html>

<style is:global>
  .article-body {
    background-color: #ffffff;
    min-height: 100vh;
    color: #1a1a1a;
  }

  /* Static top nav */
  .article-nav-static {
    width: 100%;
  }

  .article-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 720px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    gap: 1rem;
  }

  .nav-back {
    font-family: 'Lora', Georgia, serif;
    font-size: 0.9375rem;
    color: #888;
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-back:hover { color: #1a1a1a; }

  .nav-lang {
    font-family: 'Lora', Georgia, serif;
    font-size: 0.9375rem;
    color: #888;
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-lang:hover { color: #1a1a1a; }

  .article-main {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2.75rem, 8vmin, 4.75rem) 1.5rem 6rem;
  }

  .article-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .article-meta {
    font-family: 'Lora', Georgia, serif;
    font-size: 0.875rem;
    color: #888;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .meta-sep { color: #ccc; }

  .article-title {
    font-family: 'Lora', Georgia, serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    color: #1a1a1a;
    margin: 0 0 1.25rem;
    letter-spacing: -0.01em;
  }

  .article-description {
    font-family: 'Lora', Georgia, serif;
    font-size: 0.875rem;
    line-height: 1.55;
    color: #888;
    font-style: italic;
    margin: 0 auto 2rem;
    max-width: 560px;
  }

  .article-divider {
    font-family: 'Lora', Georgia, serif;
    color: #888;
    font-size: 0.75rem;
    margin-top: 2rem;
  }

  /* ── Prose ── */
  .prose-blog {
    font-family: 'Lora', Georgia, serif;
    font-size: 0.875rem;
    line-height: 1.72;
    color: #1a1a1a;
  }

  .prose-blog p {
    margin-bottom: 1.5rem;
    text-align: justify;
    hyphens: auto;
  }

  .prose-blog h2 {
    font-family: 'Lora', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }

  .prose-blog h3 {
    font-family: 'Lora', Georgia, serif;
    font-size: 0.9375rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #1a1a1a;
  }

  .prose-blog a {
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.15s;
  }

  .prose-blog a:hover { opacity: 0.6; }

  .prose-blog strong { font-weight: 600; }

  .prose-blog em { font-style: italic; }

  .prose-blog ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose-blog ol {
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose-blog li {
    margin-bottom: 0.375rem;
    text-align: left;
  }

  .prose-blog code {
    font-family: ui-monospace, 'SF Mono', monospace;
    font-size: 0.875em;
    background: #EDEDED;
    padding: 0.1em 0.35em;
    border-radius: 3px;
    color: #1a1a1a;
  }

  .prose-blog pre {
    background: #EDEDED;
    padding: 1.25rem;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }

  .prose-blog pre code {
    background: transparent;
    padding: 0;
  }

  .prose-blog blockquote {
    margin: 1.5rem 0;
    padding: 0;
    border: none;
    color: #666;
    font-style: italic;
  }

  .prose-blog hr {
    border: none;
    text-align: center;
    color: #bbb;
    font-family: ui-monospace, monospace;
    letter-spacing: 0.2em;
    font-size: 0.75rem;
    margin: 3rem 0;
  }

  .prose-blog hr::after {
    content: '╌╌╌╌';
  }

  .prose-blog table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    margin-bottom: 1.5rem;
    font-family: ui-monospace, 'SF Mono', monospace;
  }

  .prose-blog th {
    text-align: left;
    font-weight: 600;
    border-bottom: 1px solid #ccc;
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose-blog td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid #e8e7e2;
    font-size: 0.875rem;
  }
</style>
