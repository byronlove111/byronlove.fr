---
import { getCollection } from "astro:content";
import "../../styles/global.css";

const allPosts = await getCollection("blog");

// Group posts by slug_base, keep only EN entries for listing (show FR link alongside)
const bySlug = allPosts.reduce(
  (acc, post) => {
    const base = post.data.slug_base;
    if (!acc[base]) acc[base] = {};
    acc[base][post.data.lang] = post;
    return acc;
  },
  {} as Record<string, Record<string, (typeof allPosts)[0]>>
);

// Sort groups by date (descending), using EN date if available, else FR
const groups = Object.values(bySlug).sort((a, b) => {
  const dateA = (a.en ?? a.fr).data.date;
  const dateB = (b.en ?? b.fr).data.date;
  return dateB.getTime() - dateA.getTime();
});

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Blog - Byron Love</title>
    <meta name="description" content="Articles by Byron Love on building products, engineering, and the startup world." />
  </head>
  <body>
    <div class="min-h-screen bg-white">
      <div class="container max-w-2xl mx-auto px-4 py-16">
        <div class="space-y-6">
          <div class="space-y-2">
            <h1 class="text-2xl font-normal text-black">Blog</h1>
            <p class="text-sm text-black">
              <a href="/" class="underline hover:no-underline transition-all">
                ← back
              </a>
            </p>
          </div>

          <div class="pt-4 space-y-8">
            {
              groups.map((group) => {
                const primary = group.en ?? group.fr;
                const { title, date, description } = primary.data;
                const slug_base = primary.data.slug_base;

                return (
                  <div class="space-y-1">
                    <div class="flex items-baseline justify-between gap-4">
                      <a
                        href={`/blog/${slug_base}${group.en ? "-en" : "-fr"}`}
                        class="text-sm text-black underline hover:no-underline transition-all"
                      >
                        {title}
                      </a>
                      <span class="text-xs text-gray-400 shrink-0">
                        {formatDate(date)}
                      </span>
                    </div>
                    <p class="text-xs text-gray-500 leading-relaxed">
                      {description}
                    </p>
                    <div class="flex gap-2 pt-0.5">
                      {group.en && (
                        <a
                          href={`/blog/${slug_base}-en`}
                          class="text-xs text-gray-400 hover:text-black transition-colors underline hover:no-underline"
                        >
                          EN
                        </a>
                      )}
                      {group.en && group.fr && (
                        <span class="text-xs text-gray-300">/</span>
                      )}
                      {group.fr && (
                        <a
                          href={`/blog/${slug_base}-fr`}
                          class="text-xs text-gray-400 hover:text-black transition-colors underline hover:no-underline"
                        >
                          FR
                        </a>
                      )}
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
