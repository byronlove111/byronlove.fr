---
import { getCollection } from "astro:content";
import "../../styles/global.css";

const allPosts = await getCollection("blog");

const bySlug = allPosts.reduce(
  (acc, post) => {
    const base = post.data.slug_base;
    if (!acc[base]) acc[base] = {};
    acc[base][post.data.lang] = post;
    return acc;
  },
  {} as Record<string, Record<string, (typeof allPosts)[0]>>
);

const groups = Object.values(bySlug).sort((a, b) => {
  const dateA = (a.en ?? a.fr).data.date;
  const dateB = (b.en ?? b.fr).data.date;
  return dateB.getTime() - dateA.getTime();
});

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Blog — Byron Love</title>
    <meta name="description" content="Articles by Byron Love on building products, engineering, and startups." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body style="background-color: #F5F5F5; min-height: 100vh; color: #1a1a1a;">
    <div style="max-width: 720px; margin: 0 auto; padding: 4rem 1.5rem 6rem;">

      <nav style="margin-bottom: 3rem;">
        <a href="/" style="font-family: ui-monospace, 'SF Mono', monospace; font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase; color: #888; text-decoration: none;">
          ← Byron Love
        </a>
      </nav>

      <header style="margin-bottom: 3.5rem;">
        <div style="font-family: ui-monospace, 'SF Mono', monospace; font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase; color: #999; margin-bottom: 1rem;">
          Writing
        </div>
        <h1 style="font-family: 'Lora', Georgia, serif; font-size: 2rem; font-weight: 400; line-height: 1.2; color: #1a1a1a; margin: 0; letter-spacing: -0.01em;">
          Blog
        </h1>
      </header>

      <div>
        {groups.length === 0 && (
          <p style="font-family: 'Lora', Georgia, serif; font-size: 1rem; color: #888; font-style: italic;">
            No articles yet.
          </p>
        )}
        {groups.map((group) => {
          const primary = group.en ?? group.fr;
          const { title, date, description, slug_base } = primary.data;

          return (
            <a
              href={`/blog/${slug_base}${group.en ? "-en" : "-fr"}`}
              style="display: block; padding: 2rem 0; border-top: 1px solid #E8E7E2; text-decoration: none; cursor: pointer;"
              class="listing-card"
            >
              <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem;">
                <span style="font-family: 'Lora', Georgia, serif; font-size: 1.125rem; font-weight: 500; color: #1a1a1a; line-height: 1.3;">
                  {title}
                </span>
                <span style="font-family: ui-monospace, 'SF Mono', monospace; font-size: 0.625rem; letter-spacing: 0.06em; text-transform: uppercase; color: #aaa; white-space: nowrap; flex-shrink: 0;">
                  {formatDate(date)}
                </span>
              </div>
              {description && (
                <p style="font-family: 'Lora', Georgia, serif; font-size: 0.9375rem; color: #666; line-height: 1.6; margin: 0 0 0.75rem; font-style: italic;">
                  {description}
                </p>
              )}
            </a>
          );
        })}
      </div>
    </div>
  </body>
</html>

<style>
  .lang-link:hover { color: #1a1a1a !important; }
</style>
