---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Music - Byron Love</title>
	</head>
	<body>
		<div class="min-h-screen bg-white">
			<div class="container max-w-2xl mx-auto px-4 py-16">
				<div class="space-y-6">
					<div class="space-y-2">
						<h1 class="text-2xl font-normal text-black">Music</h1>
						<p class="text-sm text-black">
							<a href="/" class="underline hover:no-underline transition-all">
								← back
							</a>
						</p>
					</div>

					<div class="pt-4">
						<p class="text-sm text-black leading-relaxed mb-4">
							Albums that changed my life
						</p>
						<ul class="space-y-2 list-disc list-inside">
							<li class="text-sm text-black leading-relaxed">
								You can't kill me (070 Shake)
							</li>
							<li class="text-sm text-black leading-relaxed">
								My beautiful dark twisted fantasy (Kanye West)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Dark side of the moon (Pink Floyd)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Random Access Memories (Daft Punk)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Dangerous (Michael Jackson)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Rodeo (Travis Scott)
							</li>
							<li class="text-sm text-black leading-relaxed">
								Man on the moon (Kid Cudi)
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
