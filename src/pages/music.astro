---
import '../styles/global.css';
import BottomFade from '../components/BottomFade.astro';

const albums = [
  { label: "You can't kill me — 070 Shake", url: "https://www.youtube.com/watch?v=qEfYSU689mw" },
  { label: "My Beautiful Dark Twisted Fantasy — Kanye West", url: "https://www.youtube.com/watch?v=ofaRvNOV4SI" },
  { label: "The Dark Side of the Moon — Pink Floyd", url: "https://www.youtube.com/watch?v=QFdkM40KOhE" },
  { label: "Random Access Memories — Daft Punk", url: "https://www.youtube.com/watch?v=RRMbhEdmhYw" },
  { label: "Dangerous — Michael Jackson", url: "https://www.youtube.com/watch?v=Q_AgZUUfGsY" },
  { label: "Rodeo — Travis Scott", url: "https://www.youtube.com/watch?v=cLx87ceoNT8" },
  { label: "Man on the Moon — Kid Cudi", url: "https://www.youtube.com/watch?v=72yNKTFw9UM" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>Music — Byron Love</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div style="max-width: 680px; margin: 0 auto; padding: 4rem 1.5rem 6rem;">
      <nav style="margin-bottom: 3rem;">
        <a href="/" style="font-family: ui-monospace, 'SF Mono', monospace; font-size: 0.6875rem; letter-spacing: 0.08em; text-transform: uppercase; color: #888; text-decoration: none;">
          ← Byron Love
        </a>
      </nav>

      <h1 style="font-family: 'Lora', Georgia, serif; font-size: 1.875rem; font-weight: 400; color: #1a1a1a; margin: 0 0 0.5rem; letter-spacing: -0.01em;">
        Music
      </h1>
      <p style="font-family: 'Lora', Georgia, serif; font-size: 0.9375rem; color: #888; font-style: italic; margin: 0 0 2.5rem;">
        Albums that changed my life
      </p>

      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column;">
        {albums.map(album => (
          <li style="border-top: 1px solid #E8E7E2;">
            <a
              href={album.url}
              target="_blank"
              rel="noopener noreferrer"
              style="display: block; padding: 0.75rem 0; font-family: 'Lora', Georgia, serif; font-size: 1rem; color: #1a1a1a; line-height: 1.5; text-decoration: none; transition: opacity 0.15s;"
              onmouseover="this.style.opacity='0.5'"
              onmouseout="this.style.opacity='1'"
            >
              {album.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <BottomFade />
  </body>
</html>
